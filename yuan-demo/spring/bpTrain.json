{
	"actionType":"train",
	"modelConfig":
	{
		"name": "bp",
		"inputShape": [8, 3],
		"layers":
		[
			{"type": "flatten"},
			{"type": "dense", "units": 32, "numLayers":2},
			{"type": "dense", "units": 64, "activation": "relu"},
			{"type": "dense", "units": 1, "activation": "linear"}
		]
	},
	"training":
	{
    	"loss": "mse",
    	"accuracy": false,
    	"batchSize": 64,
    	"epochs": 100,
    	"saveModelPath": "data/model/bp"
	},
  	"data":
  	{
		"inputPathName": "data/input/train.csv",
		"minMaxPathName": "data/model/bp/minMax.json",
		"block":
		{
			"useColIndex": [1, 2, 3],
			"inputRowCount": 8,
			"inputColIndex": [0, 1, 2],
			"inputMaskIndex": [[7, 2]],
			"labelIndex": [[7, 2]]
		},
		"shuffle": true
	}
}