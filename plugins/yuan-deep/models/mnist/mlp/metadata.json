{
  "modelConfig": {
    "name": "mlp",
    "engine": "PyTorch",
    "inputShape": [28, 28],
    "layers": [
      {"type": "flatten"},
      {"type": "dense", "units": 128, "activation": "relu"},
      {"type": "dropout", "rate": 0.2},
      {"type": "dense", "units": 64, "activation": "sigmoid"},
      {"type": "dense", "units": 10}
    ]
  },
  "training": {
    "batchSize": 64,
    "loss":"crossEntropy",
    "epochs": 5
  }
}